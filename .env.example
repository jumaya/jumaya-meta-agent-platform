# GitHub Models API (your GitHub Personal Access Token)
GITHUB_TOKEN=ghp_your_personal_access_token

# Model (choose from your Copilot subscription models)
# Examples: claude-sonnet-4.6, claude-opus-4.6, gpt-5.4, gpt-4o, gemini-2.5-pro
MODEL=claude-sonnet-4.6

# MongoDB (local instance or Atlas connection string)
MONGODB_URI=mongodb://admin:devpassword@localhost:27017/meta_agent?authSource=admin

# Optional
SKILL_CACHE_TTL_DAYS=30
LOG_LEVEL=INFO
